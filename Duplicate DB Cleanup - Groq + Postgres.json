        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a database assistant. Extract the table name and class value from the user message. Respond ONLY in raw JSON with no markdown or backticks. Use this exact format: {\\\"table\\\": \\\"students\\\", \\\"class\\\": \\\"10A\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.body.message }}\"\n    }\n  ],\n  \"temperature\": 0.1\n}",
        "options": {}
      },
      "id": "8643e39d-c946-4a0a-9f59-85360dc973a2",
      "name": "AI: Identify Class",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -560,
        -704
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "lo5Gkys6z4hCHqZl",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const content = $input.first().json.choices?.[0]?.message?.content || '';\nlet cleaned = content.trim().replace(/```json|```/g, '').trim();\ntry {\n  const parsed = JSON.parse(cleaned);\n  return [{ json: { table: parsed.table || 'students', class: parsed.class || '' } }];\n} catch(e) {\n  return [{ json: { table: 'students', class: '', error: 'parse_failed', raw: cleaned } }];\n}"
      },
      "id": "d9895cd5-4dc3-465e-81a6-8c7f1e92da31",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -336,
        -704
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT class, COUNT(*) as duplicate_count, MIN(id) as keep_id FROM {{ $json.table }} WHERE class = '{{ $json.class }}' GROUP BY class HAVING COUNT(*) > 1;",
        "options": {}
      },
      "id": "9c6f0f59-113e-4584-862e-142d77b45fa2",
      "name": "Query: Find Duplicates",
      "type": "n8n-nodes-base.postgres",
