        320,
        -224
      ],
      "credentials": {
        "postgres": {
          "id": "PrfFdxjTeCuVeWDl",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO cleanup_logs (timestamp, table_name, class_value, records_deleted, status, ai_reason) VALUES (NOW(), '{{ $('Parse AI Response').first().json.table }}', '{{ $('Parse AI Response').first().json.class }}', {{ $('Parse Validation').first().json.records_to_delete }}, 'SUCCESS', '{{ $('Parse Validation').first().json.reason }}');",
        "options": {}
