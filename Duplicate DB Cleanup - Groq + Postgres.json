        "responseBody": "={{ JSON.stringify({ status: 'clean', message: 'No duplicate entries found', table: $('Parse AI Response').first().json.table, class: $('Parse AI Response').first().json.class, timestamp: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "87484a5c-62e3-42c0-8fd8-17832781bb93",
      "name": "Send Clean Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        320,
        -848
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  model: \"llama-3.3-70b-versatile\",\n  temperature: 0.1,\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are a database safety validator. Review duplicate records and decide if deletion is safe. Respond ONLY in raw JSON. Format: {\\\"approved\\\": true, \\\"reason\\\": \\\"Safe to delete\\\", \\\"records_to_delete\\\": 2}\"\n    },\n    {\n      role: \"user\",\n      content: \"Duplicates found: \" + JSON.stringify($input.all().map(i => i.json)) + \" Approve deletion? Raw JSON only.\"\n    }\n  ]\n}\n}}",
        "options": {}
      },
      "id": "423a132a-8197-4412-b6b6-80d5a635de0a",
      "name": "AI: Validate Deletion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        96,
        -544
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "lo5Gkys6z4hCHqZl",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const content = $input.first().json.choices?.[0]?.message?.content || '';\nlet cleaned = content.trim().replace(/```json|```/g, '').trim();\ntry {\n  const parsed = JSON.parse(cleaned);\n  const isApproved = parsed.approved === true || parsed.approved === 'true' || String(parsed.approved).toLowerCase() === 'true';\n  return [{ json: {\n    approved: isApproved ? 1 : 0,\n    approvedBool: isApproved,\n    reason: String(parsed.reason || 'No reason given'),\n    records_to_delete: Number(parsed.records_to_delete) || 0\n  }}];\n} catch(e) {\n  return [{ json: { approved: 0, approvedBool: false, reason: 'Validation parse failed', records_to_delete: 0 } }];\n}"
      },
      "id": "1b68269f-60ea-4b10-a143-a3dba0c59112",
      "name": "Parse Validation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        96,
        -384
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "cond-02",
              "leftValue": "={{ $json.approved }}",
              "rightValue": 1,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {
          "looseTypeValidation": true
        }
      },
      "id": "ea802d7c-0703-4bf7-b2fe-bbadc1e41bcd",
      "name": "Check Approval",
