    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ status: 'rejected', message: 'AI validation rejected the deletion', reason: $('Parse Validation').first().json.reason, timestamp: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "12703dca-2b1b-473e-bdf5-0f9dfa3af7d7",
      "name": "Send Rejected Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        -128,
        -224
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DELETE FROM {{ $('Parse AI Response').first().json.table }} WHERE id NOT IN ( SELECT MIN(id) FROM {{ $('Parse AI Response').first().json.table }} WHERE class = '{{ $('Parse AI Response').first().json.class }}' GROUP BY class, name, roll_number ) AND class = '{{ $('Parse AI Response').first().json.class }}';",
        "options": {}
      },
      "id": "dd5a11f5-4a49-4af0-a989-c45557373702",
      "name": "Execute: Delete Duplicates",
